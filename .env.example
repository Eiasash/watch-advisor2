# Supabase (required — set in Netlify dashboard for production)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase (Netlify functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Netlify functions — AI features)
CLAUDE_API_KEY=sk-ant-...

# API secret for authenticating frontend → Netlify function calls
OPEN_API_KEY=your-shared-secret

# Database migration secret
MIGRATION_SECRET=your-migration-secret

# Push notifications (VAPID keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# GitHub PAT (CI/CD workflows)
GITHUB_PAT=ghp_...
